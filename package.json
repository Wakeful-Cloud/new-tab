{
  "name": "new-tab",
  "version": "1.1.6",
  "description": "New tab extension",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist new-tab.crx new-tab.xpi new-tab.zip web-ext-artifacts",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pack:chrome:crx": "crx3 pack dist --pem new-tab.crx.pem --outfile new-tab.crx",
    "pack:chrome:zip": "cd dist && zip -r ../new-tab.zip . && cd ..",
    "pack:firefox": "web-ext sign --source-dir dist --channel unlisted && cp web-ext-artifacts/*.xpi new-tab.xpi",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/chrome": "^0.1.38",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@unocss/preset-wind4": "^66.6.7",
    "@unocss/transformer-directives": "^66.6.7",
    "idb-keyval": "^6.2.2",
    "lodash-es": "^4.17.23",
    "phosphor-solid": "^1.1.5",
    "solid-devtools": "^0.34.5",
    "solid-js": "^1.9.12",
    "typescript": "^6.0.2",
    "unocss": "^66.6.7",
    "unsplash-js": "^7.0.20",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.11",
    "vite-tsconfig-paths": "^6.1.1",
    "web-ext": "^10.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wakeful-Cloud/new-tab.git"
  },
  "author": "Wakeful-Cloud",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Wakeful-Cloud/new-tab/issues"
  },
  "homepage": "https://github.com/Wakeful-Cloud/new-tab#readme",
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.4",
    "@limegrass/eslint-plugin-import-alias": "^1.6.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security-node": "^1.1.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "prettier-plugin-multiline-arrays": "^4.1.5",
    "typescript-eslint": "^8.57.2"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": {
      "typescript": "$typescript"
    },
    "@typescript-eslint/parser": {
      "typescript": "$typescript"
    },
    "typescript-eslint": {
      "typescript": "$typescript"
    }
  }
}